{
  "$defs": {
    "CanonicalSelection": {
      "additionalProperties": false,
      "description": "Canonical source selection for one size group.",
      "properties": {
        "conflict_list": {
          "items": {
            "type": "string"
          },
          "title": "Conflict List",
          "type": "array"
        },
        "selected_source_priority": {
          "minimum": 1,
          "title": "Selected Source Priority",
          "type": "integer"
        },
        "selected_source_type": {
          "title": "Selected Source Type",
          "type": "string"
        },
        "selected_source_url": {
          "title": "Selected Source Url",
          "type": "string"
        },
        "size_group_key": {
          "title": "Size Group Key",
          "type": "string"
        }
      },
      "required": [
        "selected_source_priority",
        "selected_source_type",
        "selected_source_url",
        "size_group_key"
      ],
      "title": "CanonicalSelection",
      "type": "object"
    },
    "SourceTypeSummary": {
      "additionalProperties": false,
      "description": "Summary for one source type loop.",
      "properties": {
        "blocker_list": {
          "items": {
            "type": "string"
          },
          "title": "Blocker List",
          "type": "array"
        },
        "conflict_list": {
          "items": {
            "type": "string"
          },
          "title": "Conflict List",
          "type": "array"
        },
        "evidence_manifest_path_list": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Manifest Path List",
          "type": "array"
        },
        "source_priority": {
          "minimum": 1,
          "title": "Source Priority",
          "type": "integer"
        },
        "source_type": {
          "title": "Source Type",
          "type": "string"
        },
        "state": {
          "enum": [
            "passed",
            "failed",
            "blocked",
            "skipped"
          ],
          "title": "State",
          "type": "string"
        },
        "table_result_path_by_size_group_key_map": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Table Result Path By Size Group Key Map",
          "type": "object"
        },
        "verified_size_group_key_list": {
          "items": {
            "type": "string"
          },
          "title": "Verified Size Group Key List",
          "type": "array"
        },
        "warning_list": {
          "items": {
            "type": "string"
          },
          "title": "Warning List",
          "type": "array"
        }
      },
      "required": [
        "source_priority",
        "source_type",
        "state"
      ],
      "title": "SourceTypeSummary",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Workflow result for one brand.",
  "properties": {
    "audit_artifact_path_list": {
      "items": {
        "type": "string"
      },
      "title": "Audit Artifact Path List",
      "type": "array"
    },
    "canonical_selection_list": {
      "items": {
        "$ref": "#/$defs/CanonicalSelection"
      },
      "title": "Canonical Selection List",
      "type": "array"
    },
    "error_list": {
      "items": {
        "type": "string"
      },
      "title": "Error List",
      "type": "array"
    },
    "message": {
      "title": "Message",
      "type": "string"
    },
    "parsed_brand_key": {
      "title": "Parsed Brand Key",
      "type": "string"
    },
    "parsed_brand_name": {
      "title": "Parsed Brand Name",
      "type": "string"
    },
    "size_chart_path_list": {
      "items": {
        "type": "string"
      },
      "title": "Size Chart Path List",
      "type": "array"
    },
    "source_type_summary_list": {
      "items": {
        "$ref": "#/$defs/SourceTypeSummary"
      },
      "title": "Source Type Summary List",
      "type": "array"
    },
    "status": {
      "enum": [
        "success",
        "failed",
        "skipped"
      ],
      "title": "Status",
      "type": "string"
    }
  },
  "required": [
    "audit_artifact_path_list",
    "canonical_selection_list",
    "message",
    "parsed_brand_key",
    "parsed_brand_name",
    "size_chart_path_list",
    "source_type_summary_list",
    "status"
  ],
  "title": "BrandResult",
  "type": "object"
}
