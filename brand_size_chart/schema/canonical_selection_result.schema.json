{
  "$defs": {
    "CanonicalSelection": {
      "additionalProperties": false,
      "description": "Canonical source selection for one size group.",
      "properties": {
        "conflict_list": {
          "items": {
            "type": "string"
          },
          "title": "Conflict List",
          "type": "array"
        },
        "selected_source_priority": {
          "minimum": 1,
          "title": "Selected Source Priority",
          "type": "integer"
        },
        "selected_source_type": {
          "title": "Selected Source Type",
          "type": "string"
        },
        "selected_source_url": {
          "title": "Selected Source Url",
          "type": "string"
        },
        "size_group_key": {
          "title": "Size Group Key",
          "type": "string"
        }
      },
      "required": [
        "selected_source_priority",
        "selected_source_type",
        "selected_source_url",
        "size_group_key"
      ],
      "title": "CanonicalSelection",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Canonical selection stage result for one brand.",
  "properties": {
    "canonical_selection_list": {
      "items": {
        "$ref": "#/$defs/CanonicalSelection"
      },
      "title": "Canonical Selection List",
      "type": "array"
    },
    "conflict_list": {
      "items": {
        "type": "string"
      },
      "title": "Conflict List",
      "type": "array"
    },
    "error_list": {
      "items": {
        "type": "string"
      },
      "title": "Error List",
      "type": "array"
    },
    "message": {
      "title": "Message",
      "type": "string"
    },
    "status": {
      "enum": [
        "success",
        "failed",
        "skipped"
      ],
      "title": "Status",
      "type": "string"
    }
  },
  "required": [
    "canonical_selection_list",
    "message",
    "status"
  ],
  "title": "CanonicalSelectionResult",
  "type": "object"
}
