{
  "$defs": {
    "BrowsingError": {
      "additionalProperties": false,
      "description": "Browser or network failure for one concrete URL.",
      "properties": {
        "error": {
          "title": "Error",
          "type": "string"
        },
        "url": {
          "title": "Url",
          "type": "string"
        }
      },
      "required": [
        "error",
        "url"
      ],
      "title": "BrowsingError",
      "type": "object"
    },
    "TableExtractionArtifact": {
      "additionalProperties": false,
      "description": "Extracted size-chart table metadata with chart artifact reference.",
      "properties": {
        "applicability_description": {
          "default": "",
          "title": "Applicability Description",
          "type": "string"
        },
        "applicability_status": {
          "default": "unknown_blocked",
          "enum": [
            "priority_country_official",
            "official_global",
            "official_eu_consensus",
            "official_cross_locale_consensus",
            "duplicate_exact",
            "duplicate_units_only",
            "market_conflict",
            "unknown_blocked"
          ],
          "title": "Applicability Status",
          "type": "string"
        },
        "chart_path": {
          "title": "Chart Path",
          "type": "string"
        },
        "evidence_path_list": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Path List",
          "type": "array"
        },
        "product_type_hint_list": {
          "items": {
            "type": "string"
          },
          "title": "Product Type Hint List",
          "type": "array"
        },
        "size_group_key": {
          "title": "Size Group Key",
          "type": "string"
        },
        "source_title": {
          "title": "Source Title",
          "type": "string"
        },
        "source_type": {
          "title": "Source Type",
          "type": "string"
        },
        "source_url": {
          "title": "Source Url",
          "type": "string"
        }
      },
      "required": [
        "chart_path",
        "size_group_key",
        "source_title",
        "source_type",
        "source_url"
      ],
      "title": "TableExtractionArtifact",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Batch extraction result with generated chart artifact references.",
  "properties": {
    "browsing_error_list": {
      "items": {
        "$ref": "#/$defs/BrowsingError"
      },
      "title": "Browsing Error List",
      "type": "array"
    },
    "error_list": {
      "items": {
        "type": "string"
      },
      "title": "Error List",
      "type": "array"
    },
    "message": {
      "title": "Message",
      "type": "string"
    },
    "source_type": {
      "title": "Source Type",
      "type": "string"
    },
    "status": {
      "enum": [
        "success",
        "failed",
        "skipped"
      ],
      "title": "Status",
      "type": "string"
    },
    "table_extraction_artifact_list": {
      "items": {
        "$ref": "#/$defs/TableExtractionArtifact"
      },
      "title": "Table Extraction Artifact List",
      "type": "array"
    }
  },
  "required": [
    "message",
    "source_type",
    "status",
    "table_extraction_artifact_list"
  ],
  "title": "TableExtractionArtifactBatchResult",
  "type": "object"
}
